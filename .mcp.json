{
  "mcpServers": {
    "claude-mem": {
      "type": "stdio",
      "command": "bash",
      "args": ["scripts/mcp-runner.sh", "claude_mem.mcp_server"],
      "cwd": "${workspaceFolder}",
      "env": {
        "CHROMADB_HOST": "localhost",
        "CHROMADB_PORT": "8001"
      },
      "_comment": "Fallback memory for AMNESIA recovery per RULE-024"
    },
    "rest-api": {
      "type": "stdio",
      "command": "bash",
      "args": ["scripts/mcp-node-runner.sh", "dkmaker-mcp-rest-api"],
      "cwd": "${workspaceFolder}",
      "env": {
        "REST_BASE_URL": "http://localhost:8082"
      },
      "_comment": "Direct node invocation, pinned v0.4.0 in package.json (bypasses npx 3-30s overhead)"
    },
    "gov-core": {
      "type": "stdio",
      "command": "bash",
      "args": ["scripts/mcp-runner.sh", "governance.mcp_server_core"],
      "cwd": "${workspaceFolder}",
      "env": {
        "TYPEDB_HOST": "localhost",
        "TYPEDB_PORT": "1729",
        "CHROMADB_HOST": "localhost",
        "CHROMADB_PORT": "8001",
        "MCP_OUTPUT_FORMAT": "toon"
      },
      "_comment": "Per GAP-MCP-NAMING-001: governance → gov, TOON enabled per GAP-DATA-001"
    },
    "gov-agents": {
      "type": "stdio",
      "command": "bash",
      "args": ["scripts/mcp-runner.sh", "governance.mcp_server_agents"],
      "cwd": "${workspaceFolder}",
      "env": {
        "TYPEDB_HOST": "localhost",
        "TYPEDB_PORT": "1729"
      },
      "_comment": "Per GAP-MCP-NAMING-001: governance → gov"
    },
    "gov-sessions": {
      "type": "stdio",
      "command": "bash",
      "args": ["scripts/mcp-runner.sh", "governance.mcp_server_sessions"],
      "cwd": "${workspaceFolder}",
      "env": {
        "TYPEDB_HOST": "localhost",
        "TYPEDB_PORT": "1729",
        "CHROMADB_HOST": "localhost",
        "CHROMADB_PORT": "8001"
      },
      "_comment": "Per GAP-MCP-NAMING-001: governance → gov"
    },
    "gov-tasks": {
      "type": "stdio",
      "command": "bash",
      "args": ["scripts/mcp-runner.sh", "governance.mcp_server_tasks"],
      "cwd": "${workspaceFolder}",
      "env": {
        "TYPEDB_HOST": "localhost",
        "TYPEDB_PORT": "1729"
      },
      "_comment": "Per GAP-MCP-NAMING-001: governance → gov"
    },
    "playwright": {
      "type": "stdio",
      "command": "bash",
      "args": ["scripts/mcp-node-runner.sh", "@playwright/mcp", "--browser", "chromium"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PLAYWRIGHT_BROWSERS_PATH": "/home/oderid/.cache/ms-playwright"
      },
      "_comment": "Direct node invocation, pinned v0.0.68 in package.json (bypasses npx 3-30s overhead)"
    },
    "log-analyzer": {
      "type": "stdio",
      "command": "/home/oderid/.local/bin/uvx",
      "args": ["log-analyzer-mcp==0.1.8"],
      "env": {
        "PYTHONUNBUFFERED": "1",
        "PYTHONIOENCODING": "utf-8",
        "MCP_LOG_LEVEL": "INFO",
        "LOG_DIRECTORIES": "[\"/home/oderid/.claude/projects/-home-oderid-Documents-Vibe-sarvaja-platform\"]",
        "LOG_FILE_PATTERNS": "[\"*.jsonl\", \"*.log\", \"*.txt\"]",
        "MCP_LOG_FILE": "/home/oderid/Documents/Vibe/sarvaja/platform/logs/mcp/log_analyzer_mcp_server.log"
      },
      "_comment": "Fallback mega-session search — points at CC session JSONL files"
    }
  }
}
