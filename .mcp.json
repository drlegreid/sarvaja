{
  "mcpServers": {
    "claude-mem": {
      "type": "stdio",
      "command": "bash",
      "args": ["scripts/mcp-runner.sh", "claude_mem.mcp_server"],
      "cwd": "${workspaceFolder}",
      "env": {
        "CHROMADB_HOST": "localhost",
        "CHROMADB_PORT": "8001"
      },
      "_comment": "Fallback memory for AMNESIA recovery per RULE-024"
    },
    "rest-api": {
      "type": "stdio",
      "command": "/home/oderid/.config/nvm/versions/node/v20.19.6/bin/npx",
      "args": ["-y", "dkmaker-mcp-rest-api"],
      "env": {
        "REST_BASE_URL": "http://localhost:8082"
      },
      "_docs": "https://playbooks.com/mcp/dkmaker/mcp-rest-api"
    },
    "gov-core": {
      "type": "stdio",
      "command": "bash",
      "args": ["scripts/mcp-runner.sh", "governance.mcp_server_core"],
      "cwd": "${workspaceFolder}",
      "env": {
        "TYPEDB_HOST": "localhost",
        "TYPEDB_PORT": "1729",
        "CHROMADB_HOST": "localhost",
        "CHROMADB_PORT": "8001",
        "MCP_OUTPUT_FORMAT": "toon"
      },
      "_comment": "Per GAP-MCP-NAMING-001: governance → gov, TOON enabled per GAP-DATA-001"
    },
    "gov-agents": {
      "type": "stdio",
      "command": "bash",
      "args": ["scripts/mcp-runner.sh", "governance.mcp_server_agents"],
      "cwd": "${workspaceFolder}",
      "env": {
        "TYPEDB_HOST": "localhost",
        "TYPEDB_PORT": "1729"
      },
      "_comment": "Per GAP-MCP-NAMING-001: governance → gov"
    },
    "gov-sessions": {
      "type": "stdio",
      "command": "bash",
      "args": ["scripts/mcp-runner.sh", "governance.mcp_server_sessions"],
      "cwd": "${workspaceFolder}",
      "env": {
        "TYPEDB_HOST": "localhost",
        "TYPEDB_PORT": "1729",
        "CHROMADB_HOST": "localhost",
        "CHROMADB_PORT": "8001"
      },
      "_comment": "Per GAP-MCP-NAMING-001: governance → gov"
    },
    "gov-tasks": {
      "type": "stdio",
      "command": "bash",
      "args": ["scripts/mcp-runner.sh", "governance.mcp_server_tasks"],
      "cwd": "${workspaceFolder}",
      "env": {
        "TYPEDB_HOST": "localhost",
        "TYPEDB_PORT": "1729"
      },
      "_comment": "Per GAP-MCP-NAMING-001: governance → gov"
    },
    "playwright": {
      "type": "stdio",
      "command": "/home/oderid/.config/nvm/versions/node/v20.19.6/bin/npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--browser",
        "firefox",
        "--executable-path",
        "/home/oderid/.cache/ms-playwright/firefox-1497/firefox/firefox"
      ],
      "env": {
        "PLAYWRIGHT_BROWSERS_PATH": "/home/oderid/.cache/ms-playwright"
      },
      "_comment": "E2E UI testing automation"
    }
  }
}
