{
  "uid": "sarvaja-typedb-health",
  "title": "TypeDB Health",
  "description": "TypeDB query rate, duration percentiles, slow queries, and read/write ratio (EPIC-PERF-TELEM-V1 Phase 11)",
  "tags": ["sarvaja", "typedb", "health"],
  "timezone": "browser",
  "editable": true,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "10s",
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Query Rate (queries/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-datasource" },
      "targets": [
        {
          "expr": "sum(rate(sarvaja_typedb_query_total[5m])) by (query_type)",
          "legendFormat": "{{query_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Query Duration p50 / p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-datasource" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(sarvaja_typedb_query_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(sarvaja_typedb_query_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Slow Queries (>500ms)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-datasource" },
      "targets": [
        {
          "expr": "sum(sarvaja_typedb_query_duration_seconds_bucket{le=\"+Inf\"}) - sum(sarvaja_typedb_query_duration_seconds_bucket{le=\"0.5\"})",
          "legendFormat": "slow queries",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Read vs Write Ratio",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-datasource" },
      "targets": [
        {
          "expr": "sum(sarvaja_typedb_query_total) by (query_type)",
          "legendFormat": "{{query_type}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
