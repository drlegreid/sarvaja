{
  "uid": "sarvaja-api-performance",
  "title": "API Performance",
  "description": "Sarvaja Governance API request rate, latency percentiles, error rate, and slow endpoints (EPIC-PERF-TELEM-V1 Phase 11)",
  "tags": ["sarvaja", "api", "performance"],
  "timezone": "browser",
  "editable": true,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "10s",
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-datasource" },
      "targets": [
        {
          "expr": "sum(rate(sarvaja_http_requests_total[5m])) by (method)",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Latency Percentiles (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-datasource" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(sarvaja_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(sarvaja_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(sarvaja_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Error Rate (5xx/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-datasource" },
      "targets": [
        {
          "expr": "sum(rate(sarvaja_http_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "5xx/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Slow Requests (>1s)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-datasource" },
      "targets": [
        {
          "expr": "sum(sarvaja_http_request_duration_seconds_bucket{le=\"+Inf\"}) - sum(sarvaja_http_request_duration_seconds_bucket{le=\"1.0\"})",
          "legendFormat": "slow requests",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Top 10 Slowest Endpoints (avg latency)",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-datasource" },
      "targets": [
        {
          "expr": "topk(10, sum(rate(sarvaja_http_request_duration_seconds_sum[5m])) by (path) / sum(rate(sarvaja_http_request_duration_seconds_count[5m])) by (path))",
          "legendFormat": "{{path}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": { "path": "Endpoint", "Value": "Avg Latency (s)" }
          }
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
