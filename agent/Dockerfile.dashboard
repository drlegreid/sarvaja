# Governance Dashboard - Trame UI
# Per RULE-019: UI/UX Design Standards
FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1
ENV TRAME_DEFAULT_HOST=0.0.0.0

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python dependencies
COPY requirements.txt /tmp/requirements.txt
COPY requirements-test.txt /tmp/requirements-test.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt && \
    pip install --no-cache-dir -r /tmp/requirements-test.txt

# Copy application code (context is project root)
COPY agent /app/agent
COPY governance /app/governance
# GAP-UI-038: Include docs and evidence for file viewer API
COPY docs /app/docs
COPY evidence /app/evidence
# WORKFLOW-SHELL-01-v1: Include tests for self-assessment
COPY tests /app/tests
# EPIC-DRY-001: Include shared constants module
COPY shared /app/shared

# Create entrypoint that runs both Dashboard + API
# Task 0.2: API uses uvicorn --reload for hot-reload on code changes
# Per GAP-WORKFLOW-RELOAD-001: Dashboard uses watchdog watcher for auto-restart
RUN echo '#!/bin/sh\n\
echo "=== Sarvaja Governance Stack ==="\n\
echo "Dashboard Port: ${DASHBOARD_PORT:-8081}"\n\
echo "API Port: ${API_PORT:-8082}"\n\
echo "TypeDB: ${TYPEDB_HOST:-typedb}:${TYPEDB_PORT:-1729}"\n\
cd /app\n\
\n\
# Start API with auto-reload in background\n\
echo "Starting Governance API on port ${API_PORT:-8082} (auto-reload)..."\n\
python -m uvicorn governance.api:app --host 0.0.0.0 --port ${API_PORT:-8082} \\\n\
  --reload --reload-dir /app/governance --reload-dir /app/shared &\n\
API_PID=$!\n\
\n\
# Give API time to start\n\
sleep 2\n\
\n\
# Start Dashboard with file watcher for hot-reload (GAP-WORKFLOW-RELOAD-001)\n\
echo "Starting Governance Dashboard on port ${DASHBOARD_PORT:-8081} (with file watcher)..."\n\
exec python -m agent.dashboard_watcher\n\
' > /entrypoint.sh && chmod +x /entrypoint.sh

EXPOSE 8081 8082

ENTRYPOINT ["/entrypoint.sh"]
