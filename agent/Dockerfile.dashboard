# Governance Dashboard - Trame UI
# Per RULE-019: UI/UX Design Standards
FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1
ENV TRAME_DEFAULT_HOST=0.0.0.0

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python dependencies
COPY requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

# Copy application code (context is project root)
COPY agent /app/agent
COPY governance /app/governance
# GAP-UI-038: Include docs and evidence for file viewer API
COPY docs /app/docs
COPY evidence /app/evidence

# Create entrypoint that runs both Dashboard + API
RUN echo '#!/bin/sh\n\
echo "=== Sim.ai Governance Stack ==="\n\
echo "Dashboard Port: ${DASHBOARD_PORT:-8081}"\n\
echo "API Port: ${API_PORT:-8082}"\n\
echo "TypeDB: ${TYPEDB_HOST:-typedb}:${TYPEDB_PORT:-1729}"\n\
cd /app\n\
\n\
# Start API in background\n\
echo "Starting Governance API on port ${API_PORT:-8082}..."\n\
python -m governance.api --port ${API_PORT:-8082} &\n\
API_PID=$!\n\
\n\
# Give API time to start\n\
sleep 2\n\
\n\
# Start Dashboard in foreground\n\
echo "Starting Governance Dashboard on port ${DASHBOARD_PORT:-8081}..."\n\
exec python -m agent.governance_dashboard --port ${DASHBOARD_PORT:-8081}\n\
' > /entrypoint.sh && chmod +x /entrypoint.sh

EXPOSE 8081 8082

ENTRYPOINT ["/entrypoint.sh"]
