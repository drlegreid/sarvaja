# E2E Exploration Attributes
# TypeDB attributes for LLM-driven E2E testing (RULE-020)
# Part of: EPIC-DR-012 Schema Modularization
# Created: 2026-01-17

define

# =============================================================================
# E2E EXPLORATION ATTRIBUTES (RULE-020)
# =============================================================================

attribute session-id value string;

attribute session-name value string;

attribute session-url value string;

attribute started-at value datetime;

attribute completed-at value datetime;

attribute heuristics-applied value string;


# Exploration step attributes
attribute target-selector value string;

attribute step-id value string;

attribute step-value value string;

attribute step-description value string;

attribute step-success value boolean;

attribute step-error value string;


# Test case attributes
attribute test-id value string;

attribute test-name value string;

attribute generated-from value string;

attribute robot-code value string;

attribute test-tags value string;


# Test failure attributes
attribute failure-id value string;

attribute failure-test-name value string;

attribute failure-step value string;

attribute failure-error value string;

attribute failure-screenshot value string;

attribute analysis-classification value string;

attribute analysis-root-cause value string;

attribute analysis-fix value string;

attribute analysis-confidence value double;

