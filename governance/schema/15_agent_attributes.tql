# Multi-Agent Governance Attributes
# TypeDB attributes for agent trust and proposals (RULE-011)
# Part of: EPIC-DR-012 Schema Modularization
# Created: 2026-01-17

define

# =============================================================================
# AGENT ATTRIBUTES (RULE-011)
# =============================================================================

agent-id sub attribute, value string;
agent-name sub attribute, value string;
agent-type sub attribute, value string;    # "claude-code", "docker-agent", "sync-agent"
agent-capabilities sub attribute, value string; # Per GAP-AGENT-004: comma-separated list
trust-score sub attribute, value double;   # 0.0 to 1.0
compliance-rate sub attribute, value double;
accuracy-rate sub attribute, value double;
tenure-days sub attribute, value long;

# =============================================================================
# PROPOSAL ATTRIBUTES (RULE-011)
# =============================================================================

proposal-id sub attribute, value string;
proposal-type sub attribute, value string;    # "create", "modify", "deprecate"
proposal-status sub attribute, value string;  # "pending", "approved", "rejected", "disputed", "escalated"
evidence sub attribute, value string;
hypothesis sub attribute, value string;
proposal-created-at sub attribute, value datetime;

# =============================================================================
# VOTE ATTRIBUTES (RULE-011)
# =============================================================================

vote-value sub attribute, value string;       # "approve", "reject", "abstain"
vote-reason sub attribute, value string;
vote-timestamp sub attribute, value datetime;
vote-weight sub attribute, value double;      # Trust-weighted vote

# =============================================================================
# DISPUTE ATTRIBUTES (RULE-011)
# =============================================================================

dispute-id sub attribute, value string;
dispute-reason sub attribute, value string;
semantic-analysis sub attribute, value string;
resolution-method sub attribute, value string; # "consensus", "evidence", "authority", "escalate"
escalation-trigger sub attribute, value string; # "VETO", "STEER", "AMBIGUITY", "DEADLOCK", "CRITICAL"

# =============================================================================
# AGENT ACTION ATTRIBUTES (RULE-011)
# =============================================================================

action-type sub attribute, value string;       # "propose", "vote", "dispute", "resolve"
action-timestamp sub attribute, value datetime;
action-outcome sub attribute, value string;    # "success", "failure", "pending"

# =============================================================================
# TYPED REFERENCE ATTRIBUTES (P10.7 - Option B)
# =============================================================================

has-authority sub attribute, value boolean;    # Decision authority from task outcome
