# Sim.ai Governance Schema
# TypeDB 3.x syntax schema for rules, decisions, and inference
# Created: 2024-12-24 (DECISION-003)
# Updated: 2024-12-24 (RULE-011) - Added multi-agent governance entities
# Updated: 2024-12-24 (RULE-013) - Added document entity and gap-rule cross-referencing
# Updated: 2024-12-25 (RULE-020) - Added E2E exploration session entities
# Updated: 2026-01-13 (META-TAXON-01-v1) - Added semantic-id attribute to rule-entity

define

# =============================================================================
# ENTITY TYPES
# =============================================================================

entity rule-entity,
    owns rule-id,
    owns semantic-id,            # META-TAXON-01-v1: Semantic ID (e.g., SESSION-EVID-01-v1)
    owns rule-name,
    owns category,
    owns priority,
    owns status,
    owns rule-type,
    owns directive,
    owns rule-tags,              # RD-WORKSPACE: Comma-separated skill tags (e.g., "research,analysis")
    owns applicable-roles,       # RD-WORKSPACE: Comma-separated agent roles (e.g., "RESEARCH,CODING")
    owns created-date,
    owns applicability,              # RD-RULE-APPLICABILITY: MANDATORY|RECOMMENDED|FORBIDDEN|CONDITIONAL
    plays rule-dependency:dependent,
    plays rule-dependency:dependency,
    plays decision-affects:affected-rule,
    plays rule-conflict:conflicting-rule,
    plays proposal-affects:affected-rule,   # RULE-011: proposals can affect rules
    plays agent-action:action-target,       # RULE-011: agents act on rules
    plays gap-rule-reference:governing-rule,       # RULE-013: rules govern gaps
    plays document-references-rule:referenced-rule, # RULE-013: rules referenced by docs
    plays entity-vector:embedded-entity,   # P7.1: vector embeddings
    plays implements-rule:implemented-rule,  # P11.3: tasks implement rules
    plays session-applied-rule:applied-rule, # P11.3: sessions apply rules
    plays agent-capability:governing-rule;   # P2-12: rule→agent capability bindings

entity decision,
    owns decision-id,
    owns decision-name,
    owns context,
    owns rationale,
    owns decision-status,
    owns decision-date,
    plays decision-affects:affecting-decision,
    plays decision-supersedes:superseding,
    plays decision-supersedes:superseded,
    plays document-references-decision:referenced-decision, # RULE-013: decisions referenced by docs
    plays entity-vector:embedded-entity,   # P7.1: vector embeddings
    plays session-decision:session-made-decision, # P11.3: sessions make decisions
    plays task-outcome:outcome-decision;   # P10.7: Decision as task outcome with authority

entity task,
    owns task-id,
    owns task-name,
    owns task-status,
    owns task-resolution,                        # GAP-UI-046: NONE, DEFERRED, IMPLEMENTED, VALIDATED, CERTIFIED
    owns resolution-notes,                       # P17: resolution narrative
    owns task-body,
    owns task-priority,                          # BUG-TASK-TAXONOMY-001: LOW, MEDIUM, HIGH, CRITICAL
    owns task-type,                              # BUG-TASK-TAXONOMY-001: bug, feature, chore, research
    owns task-summary,                           # Phase 9c: structured one-line intent
    owns phase,
    owns agent-id,                               # Agent assigned to task (E2E tests)
    owns task-evidence,                          # Completion evidence/notes (E2E tests)
    owns task-completed-at,                      # Completion timestamp (E2E tests)
    owns task-created-at,                        # Creation timestamp (GAP-UI-035)
    owns task-claimed-at,                        # Claim timestamp (GAP-UI-035)
    owns gap-reference,                          # DEPRECATED: Use references-gap relation (P10.7)
    # GAP-TASK-LINK-004: Task detail sections (per TASK-TECH-01-v1)
    owns task-business,                          # Why - User problem, business value
    owns task-design,                            # What - Functional requirements
    owns task-architecture,                      # How - Technical approach
    owns task-test,                              # Verification - Test plan, evidence
    plays task-blocked:blocked-task,
    plays task-blocked:blocking-rule,
    plays implements-rule:implementing-task,
    plays completed-in:completed-task,
    plays evidence-supports:supported-task,
    plays references-gap:referencing-task,       # P10.7: Typed task→gap reference
    plays task-outcome:source-task,              # P10.7: Task can produce decisions
    # GAP-TASK-LINK-003: Task relationship roles
    plays task-hierarchy:parent-task,
    plays task-hierarchy:child-task,
    plays task-blocks-task:blocking-task,
    plays task-blocks-task:blocked-dep-task,
    plays task-related:related-task-a,
    plays task-related:related-task-b,
    plays task-commit:implemented-task,  # GAP-TASK-LINK-002
    plays document-references-task:referenced-task,  # BUG-TASK-DOC-001: task document management
    plays epic-contains-task:epic-task,  # Project hierarchy (GOV-PROJECT-01-v1)
    plays workspace-has-task:assigned-task,  # EPIC-GOV-TASKS-V2 Phase 4: workspace linking
    plays story-contains-task:story-task;  # FIX-HIER-002: Story hierarchy

entity gap,
    owns gap-id,
    owns gap-name,
    owns gap-status,
    owns severity,
    owns location,              # file:line or doc:section (RULE-013)
    plays gap-requires:requiring-gap,
    plays gap-requires:required-rule,
    plays gap-rule-reference:referencing-gap,  # RULE-013: gaps reference rules
    plays document-references-gap:referenced-gap, # RULE-013: gaps referenced by docs
    plays references-gap:referenced-gap;       # P10.7: Tasks can reference gaps

# =============================================================================
# WORK SESSION ENTITY (P11.3 - Entity Linkage)
# =============================================================================

# Work session entity for tracking development sessions
entity work-session,
    owns session-id,
    owns session-name,
    owns session-description,
    owns session-file-path,
    owns agent-id,                               # Agent that created the session (E2E tests)
    owns started-at,
    owns completed-at,
    owns cc-session-uuid,                        # Claude Code internal UUID
    owns cc-project-slug,                        # Project slug (e.g., "sarvaja-platform")
    owns cc-git-branch,                          # Git branch at session time
    owns cc-tool-count,                          # Total tool invocations
    owns cc-thinking-chars,                      # Reasoning token volume
    owns cc-compaction-count,                    # Context compressions
    owns cc-external-name,                       # Claude Code session name (customTitle)
    plays completed-in:hosting-session,
    plays has-evidence:evidence-session,
    plays session-applied-rule:applying-session,
    plays session-decision:deciding-session,
    plays project-has-session:project-session;

# Evidence file entity for session artifacts
entity evidence-file,
    owns evidence-id,
    owns evidence-source,
    owns evidence-type,
    owns evidence-content-preview,
    owns evidence-created-at,
    plays has-evidence:session-evidence,
    plays evidence-supports:supporting-evidence;

# =============================================================================
# PROJECT HIERARCHY ENTITIES (GOV-PROJECT-01-v1)
# =============================================================================

# Project entity - top-level organizational unit
entity project,
    owns project-id,
    owns project-name,
    owns project-path,
    owns project-type,                           # "governance", "gamedev", "video", "financial", "ml", "generic"
    owns project-description,
    owns project-created-at,
    plays project-contains-plan:parent-project,
    plays project-has-session:session-project,
    plays project-has-workspace:owning-project;

# Workspace entity - organizational context within a project (EPIC-GOV-TASKS-V2)
entity workspace,
    owns workspace-id,
    owns workspace-name,
    owns workspace-type,                         # "governance", "gamedev", "video", etc.
    owns workspace-description,
    owns workspace-status,                       # "active", "archived"
    owns workspace-created-at,
    plays project-has-workspace:workspace-member,
    plays workspace-has-agent:agent-workspace,
    plays workspace-has-task:task-workspace;  # EPIC-GOV-TASKS-V2 Phase 4: task linking

# Plan entity - a planned body of work within a project
entity plan,
    owns plan-id,
    owns plan-name,
    owns session-description,
    plays project-contains-plan:child-plan,
    plays plan-contains-epic:parent-plan;

# Epic entity - a large feature/initiative within a plan
entity epic,
    owns epic-id,
    owns epic-name,
    owns session-description,
    plays plan-contains-epic:child-epic,
    plays epic-contains-task:parent-epic,
    plays epic-contains-story:parent-epic;

# Story entity - user story/feature within an epic (FIX-HIER-002)
entity story,
    owns story-id,
    owns story-name,
    owns story-description,
    owns story-status,
    owns story-priority,
    owns story-created-at,
    plays epic-contains-story:child-story,
    plays story-contains-task:parent-story;

# Git commit entity (GAP-TASK-LINK-002)
entity git-commit,
    owns commit-sha,
    owns commit-message,
    plays task-commit:implementing-commit;

# =============================================================================
# DOCUMENT CROSS-REFERENCING ENTITIES (RULE-013)
# =============================================================================

# =============================================================================
# VECTOR EMBEDDING ENTITIES (P7.1 - TypeDB 2.x Bridge)
# =============================================================================
# NOTE: TypeDB 3.x will have native vector support (double[]).
# This is a bridge pattern for TypeDB 2.x that stores embeddings as JSON strings.
# Similarity computation is done externally in Python (numpy/sklearn).
# See DECISION-003: TypeDB-First Strategy for migration plan.

# Vector document entity - stores text with embedding
entity vector-document,
    owns vector-id,
    owns vector-content,
    owns vector-embedding,       # JSON-encoded float array
    owns vector-model,           # Embedding model name (e.g., "text-embedding-3-small")
    owns vector-dimension,       # Embedding dimensions (e.g., 1536)
    owns vector-source,          # Source identifier (rule-id, decision-id, session-id)
    owns vector-source-type,     # Source type (rule, decision, session, document)
    owns vector-created-at,
    plays vector-similarity:source-vector,
    plays vector-similarity:similar-vector,
    plays entity-vector:entity-embedding;

# Similarity relation (precomputed top-k neighbors)
# This allows TypeDB to store and query precomputed similarities
relation vector-similarity,
    relates source-vector,
    relates similar-vector,
    owns similarity-score;       # Cosine similarity 0.0-1.0

# Link vector to source entity (rule, decision, etc.)
relation entity-vector,
    relates embedded-entity,
    relates entity-embedding;

# =============================================================================
# E2E EXPLORATION ENTITIES (RULE-020)
# =============================================================================

# Exploration session for LLM-driven E2E testing
entity exploration-session,
    owns session-id,
    owns session-name,
    owns session-url,
    owns started-at,
    owns completed-at,
    owns heuristics-applied,
    plays session-step:session,
    plays generates:generating-session;

# Exploration step within a session
entity exploration-step,
    owns step-id,
    owns action-type,
    owns target-selector,
    owns step-value,
    owns step-description,
    owns step-success,
    owns step-error,
    plays session-step:step;

# Generated test case from exploration
entity test-case,
    owns test-id,
    owns test-name,
    owns generated-from,
    owns robot-code,
    owns test-tags,
    plays generates:generated-test,
    plays test-failed:generated-test;

# Test failure for LLM analysis
entity test-failure,
    owns failure-id,
    owns failure-test-name,
    owns failure-step,
    owns failure-error,
    owns failure-screenshot,
    owns analysis-classification,
    owns analysis-root-cause,
    owns analysis-fix,
    owns analysis-confidence,
    plays test-failed:failure;

# Document entity for cross-referencing
entity document,
    owns document-id,
    owns document-title,
    owns document-path,         # Local path: docs/RULES.md
    owns document-url,          # Remote: webdav://... or github://...
    owns document-type,         # markdown, yaml, json, code
    owns document-storage,      # local, webdav, github
    owns last-modified,
    owns content-hash,
    plays document-references-rule:referencing-document,
    plays document-references-decision:referencing-document,
    plays document-references-gap:referencing-document,
    plays document-references-task:referencing-document;  # BUG-TASK-DOC-001: task document linking

# =============================================================================
# MULTI-AGENT GOVERNANCE ENTITIES (RULE-011)
# =============================================================================

# Agent entity for trust tracking
entity agent,
    owns agent-id,
    owns agent-name,
    owns agent-type,        # "claude-code", "docker-agent", "sync-agent"
    owns agent-capabilities, # Per GAP-AGENT-004: comma-separated capability list
    owns trust-score,       # 0.0 to 1.0
    owns compliance-rate,   # Historical compliance percentage
    owns accuracy-rate,     # Decision accuracy
    owns tenure-days,       # Days active
    plays proposes:proposer,
    plays vote:voter,
    plays dispute:disputer,
    plays agent-action:acting-agent,
    plays agent-capability:capable-agent,         # P2-12: rule→agent bindings
    plays workspace-has-agent:assigned-agent;     # P2-12: workspace→agent links

# Proposal for rule changes
entity proposal,
    owns proposal-id,
    owns proposal-type,     # "create", "modify", "deprecate"
    owns proposal-status,   # "pending", "approved", "rejected", "disputed"
    owns evidence,
    owns hypothesis,
    owns proposal-created-at,
    plays proposes:proposed-change,
    plays vote:vote-target,
    plays dispute:disputed-proposal,
    plays proposal-affects:proposing,
    plays requires-escalation:escalated-proposal;

# =============================================================================
# ATTRIBUTE TYPES
# =============================================================================

# Rule attributes
attribute rule-id, value string;
attribute semantic-id, value string;  # META-TAXON-01-v1: Semantic ID (e.g., SESSION-EVID-01-v1)
attribute rule-name, value string;
attribute category, value string;  # governance, architecture, testing, etc.
attribute priority, value string;  # CRITICAL, HIGH, MEDIUM, LOW
attribute status, value string;    # ACTIVE, PROPOSED, DISABLED (DEPRECATED maps to DISABLED)
attribute rule-type, value string; # FOUNDATIONAL, OPERATIONAL, TECHNICAL, META, LEAF
attribute directive, value string;
attribute rule-tags, value string;        # RD-WORKSPACE: Comma-separated skill tags
attribute applicable-roles, value string; # RD-WORKSPACE: Comma-separated agent roles
attribute created-date, value datetime;
attribute applicability, value string;  # RD-RULE-APPLICABILITY: MANDATORY|RECOMMENDED|FORBIDDEN|CONDITIONAL

# Decision attributes
attribute decision-id, value string;
attribute decision-name, value string;
attribute context, value string;
attribute rationale, value string;
attribute decision-status, value string;  # APPROVED, PENDING, SUPERSEDED
attribute decision-date, value datetime;

# Task attributes
attribute task-id, value string;
attribute task-name, value string;
attribute task-status, value string;  # GAP-UI-046: OPEN, IN_PROGRESS, CLOSED (lifecycle)
attribute task-resolution, value string;  # GAP-UI-046: NONE, DEFERRED, IMPLEMENTED, VALIDATED, CERTIFIED (outcome)
attribute resolution-notes, value string;  # P17: resolution narrative
attribute task-body, value string;    # P11.3: detailed task description
attribute task-evidence, value string; # Completion evidence/notes (E2E tests)
attribute task-completed-at, value datetime; # Completion timestamp (E2E tests)
attribute task-created-at, value datetime;   # Creation timestamp (GAP-UI-035)
attribute task-claimed-at, value datetime;   # Claim timestamp (GAP-UI-035)
attribute phase, value string;
attribute gap-reference, value string; # P11.3: linked gap ID

# BUG-TASK-TAXONOMY-001: Task classification attributes
attribute task-priority, value string;  # LOW, MEDIUM, HIGH, CRITICAL
attribute task-type, value string;      # bug, feature, chore, research
attribute task-summary, value string;  # Phase 9c: structured one-line intent

# Task detail section attributes (GAP-TASK-LINK-004, TASK-TECH-01-v1)
attribute task-business, value string;      # Why - User problem, business value
attribute task-design, value string;        # What - Functional requirements
attribute task-architecture, value string;  # How - Technical approach
attribute task-test, value string;          # Verification - Test plan, evidence

# Git commit attributes (GAP-TASK-LINK-002)
attribute commit-sha, value string;    # Short (7) or full (40) SHA
attribute commit-message, value string; # Commit message

# Work Session attributes (P11.3)
attribute session-description, value string;
attribute session-file-path, value string;   # Path to session evidence file

# Claude Code session attributes (SESSION-CC-01-v1)
attribute cc-session-uuid, value string;       # CC internal UUID
attribute cc-project-slug, value string;       # Project slug (e.g., "sarvaja-platform")
attribute cc-git-branch, value string;         # Git branch at session time
attribute cc-tool-count, value integer;           # Total tool invocations
attribute cc-thinking-chars, value integer;       # Reasoning token volume
attribute cc-compaction-count, value integer;     # Context compressions
attribute cc-external-name, value string;        # Claude Code session name (customTitle)

# Project hierarchy attributes (GOV-PROJECT-01-v1)
attribute project-id, value string;
attribute project-name, value string;
attribute project-path, value string;          # Project root directory path
attribute project-type, value string;          # "governance", "gamedev", etc.
attribute project-description, value string;
attribute project-created-at, value datetime;
attribute plan-id, value string;
attribute plan-name, value string;
attribute epic-id, value string;
attribute epic-name, value string;

# Story attributes (FIX-HIER-002)
attribute story-id, value string;
attribute story-name, value string;
attribute story-description, value string;
attribute story-status, value string;
attribute story-priority, value string;
attribute story-created-at, value datetime;

# Workspace attributes (EPIC-GOV-TASKS-V2)
attribute workspace-id, value string;
attribute workspace-name, value string;
attribute workspace-type, value string;
attribute workspace-description, value string;
attribute workspace-status, value string;      # "active", "archived"
attribute workspace-created-at, value datetime;

# Evidence file attributes (P11.3)
attribute evidence-id, value string;
attribute evidence-source, value string;      # File path
attribute evidence-type, value string;        # markdown, screenshot, log
attribute evidence-content-preview, value string;  # First 500 chars
attribute evidence-created-at, value datetime;

# Gap attributes
attribute gap-id, value string;
attribute gap-name, value string;
attribute gap-status, value string;  # OPEN, RESOLVED, DEFERRED
attribute severity, value string;
attribute location, value string;    # file:line or doc:section (RULE-013)

# Document attributes (RULE-013)
attribute document-id, value string;
attribute document-title, value string;
attribute document-path, value string;   # Local path: docs/RULES.md
attribute document-url, value string;    # Remote: webdav://... or github://...
attribute document-type, value string;   # markdown, yaml, json, code
attribute document-storage, value string; # local, webdav, github
attribute last-modified, value datetime;
attribute content-hash, value string;

# Vector embedding attributes (P7.1 - TypeDB 2.x Bridge)
attribute vector-id, value string;           # Unique vector ID (uuid)
attribute vector-content, value string;      # Original text content
attribute vector-embedding, value string;    # JSON-encoded float[] (e.g., "[0.1, 0.2, ...]")
attribute vector-model, value string;        # Embedding model (e.g., "text-embedding-3-small")
attribute vector-dimension, value integer;      # Embedding dimensions (e.g., 1536, 768)
attribute vector-source, value string;       # Source ID (rule-id, decision-id, etc.)
attribute vector-source-type, value string;  # Source type (rule, decision, session)
attribute vector-created-at, value datetime;
attribute similarity-score, value double;    # Cosine similarity 0.0-1.0

# E2E Exploration attributes (RULE-020)
attribute session-id, value string;
attribute session-name, value string;
attribute session-url, value string;
attribute started-at, value datetime;
attribute completed-at, value datetime;
attribute heuristics-applied, value string;  # Comma-separated list
attribute target-selector, value string;     # CSS/XPath selector
attribute step-id, value string;
attribute step-value, value string;          # Input value for type actions
attribute step-description, value string;
attribute step-success, value boolean;
attribute step-error, value string;
attribute test-id, value string;
attribute test-name, value string;
attribute generated-from, value string;      # session-id reference
attribute robot-code, value string;          # Generated Robot Framework code
attribute test-tags, value string;           # Comma-separated tags
attribute failure-id, value string;
attribute failure-test-name, value string;
attribute failure-step, value string;
attribute failure-error, value string;
attribute failure-screenshot, value string;  # Path to screenshot
attribute analysis-classification, value string; # app_bug, test_issue, environment
attribute analysis-root-cause, value string;
attribute analysis-fix, value string;
attribute analysis-confidence, value double; # 0.0 to 1.0

# Agent attributes (RULE-011)
attribute agent-id, value string;
attribute agent-name, value string;
attribute agent-type, value string;    # "claude-code", "docker-agent", "sync-agent"
attribute agent-capabilities, value string; # Per GAP-AGENT-004: comma-separated list
attribute trust-score, value double;   # 0.0 to 1.0
attribute compliance-rate, value double;
attribute accuracy-rate, value double;
attribute tenure-days, value integer;

# Proposal attributes (RULE-011)
attribute proposal-id, value string;
attribute proposal-type, value string;    # "create", "modify", "deprecate"
attribute proposal-status, value string;  # "pending", "approved", "rejected", "disputed", "escalated"
attribute evidence, value string;
attribute hypothesis, value string;
attribute proposal-created-at, value datetime;

# Vote attributes (RULE-011)
attribute vote-value, value string;       # "approve", "reject", "abstain"
attribute vote-reason, value string;
attribute vote-timestamp, value datetime;
attribute vote-weight, value double;      # Trust-weighted vote

# Dispute attributes (RULE-011)
attribute dispute-id, value string;
attribute dispute-reason, value string;
attribute semantic-analysis, value string;
attribute resolution-method, value string; # "consensus", "evidence", "authority", "escalate"
attribute escalation-trigger, value string; # "VETO", "STEER", "AMBIGUITY", "DEADLOCK", "CRITICAL"

# Agent action attributes (RULE-011)
attribute action-type, value string;       # "propose", "vote", "dispute", "resolve"
attribute action-timestamp, value datetime;
attribute action-outcome, value string;    # "success", "failure", "pending"

# Typed reference attributes (P10.7 - Option B)
attribute has-authority, value boolean;    # Decision authority from task outcome

# =============================================================================
# RELATION TYPES
# =============================================================================

# Rule A depends on Rule B
relation rule-dependency,
    relates dependent,
    relates dependency;

# Decision affects Rule
relation decision-affects,
    relates affecting-decision,
    relates affected-rule;

# Decision supersedes another Decision
relation decision-supersedes,
    relates superseding,
    relates superseded;

# Task is blocked by Rule
relation task-blocked,
    relates blocked-task,
    relates blocking-rule;

# =============================================================================
# TASK RELATIONSHIP RELATIONS (GAP-TASK-LINK-003)
# =============================================================================

# Task parent-child hierarchy (task decomposition)
relation task-hierarchy,
    relates parent-task,
    relates child-task;

# Task blocks another task (sequencing dependency)
relation task-blocks-task,
    relates blocking-task,
    relates blocked-dep-task;

# Task is related to another task (soft association)
relation task-related,
    relates related-task-a,
    relates related-task-b;

# Task implemented by git commit (GAP-TASK-LINK-002)
relation task-commit,
    relates implementing-commit,
    relates implemented-task;

# Gap requires Rule to be resolved
relation gap-requires,
    relates requiring-gap,
    relates required-rule;

# =============================================================================
# ENTITY LINKAGE RELATIONS (P11.3 - GAP-DATA-002)
# =============================================================================

# Task implements a rule (shows which rule a task is implementing)
relation implements-rule,
    relates implementing-task,
    relates implemented-rule;

# Task completed in a session (tracks when/where work was done)
relation completed-in,
    relates completed-task,
    relates hosting-session;

# Session has evidence files (links sessions to their artifacts)
relation has-evidence,
    relates evidence-session,
    relates session-evidence;

# Session applied a rule (rules used/followed during session)
relation session-applied-rule,
    relates applying-session,
    relates applied-rule;

# Session made a decision (decisions made during session)
relation session-decision,
    relates deciding-session,
    relates session-made-decision;

# Evidence supports a task (evidence proving task completion)
relation evidence-supports,
    relates supporting-evidence,
    relates supported-task;

# =============================================================================
# TYPED REFERENCE RELATIONS (P10.7 - Option B)
# =============================================================================

# Task references a gap (replaces gap-reference attribute)
relation references-gap,
    relates referencing-task,
    relates referenced-gap;

# Decision is outcome of a task with authority
relation task-outcome,
    relates outcome-decision,
    relates source-task,
    owns has-authority;

# =============================================================================
# PROJECT HIERARCHY RELATIONS (GOV-PROJECT-01-v1)
# =============================================================================

# Project contains plans
relation project-contains-plan,
    relates parent-project,
    relates child-plan;

# Plan contains epics
relation plan-contains-epic,
    relates parent-plan,
    relates child-epic;

# Epic contains tasks
relation epic-contains-task,
    relates parent-epic,
    relates epic-task;

# Epic contains stories (FIX-HIER-002)
relation epic-contains-story,
    relates parent-epic,
    relates child-story;

# Story contains tasks (FIX-HIER-002)
relation story-contains-task,
    relates parent-story,
    relates story-task;

# Project has sessions (links CC sessions to their project)
relation project-has-session,
    relates session-project,
    relates project-session;

# =============================================================================
# DOCUMENT CROSS-REFERENCING RELATIONS (RULE-013)
# =============================================================================

# Gap references a governing rule (for meta-referencing per RULE-013)
relation gap-rule-reference,
    relates referencing-gap,
    relates governing-rule;

# Document references a rule
relation document-references-rule,
    relates referencing-document,
    relates referenced-rule;

# Document references a decision
relation document-references-decision,
    relates referencing-document,
    relates referenced-decision;

# Document references a gap
relation document-references-gap,
    relates referencing-document,
    relates referenced-gap;

# Document references a task (BUG-TASK-DOC-001: task document management)
relation document-references-task,
    relates referencing-document,
    relates referenced-task;

# Rules that conflict with each other
relation rule-conflict,
    relates conflicting-rule;

# =============================================================================
# E2E EXPLORATION RELATIONS (RULE-020)
# =============================================================================

# Session contains steps
relation session-step,
    relates session,
    relates step;

# Session generates test cases
relation generates,
    relates generating-session,
    relates generated-test;

# Test case failed (for analysis)
relation test-failed,
    relates generated-test,
    relates failure;

# =============================================================================
# MULTI-AGENT GOVERNANCE RELATIONS (RULE-011)
# =============================================================================

# Proposes relation (agent proposes a change)
relation proposes,
    relates proposer,
    relates proposed-change;

# Vote on a proposal
relation vote,
    relates voter,
    relates vote-target,
    owns vote-value,
    owns vote-reason,
    owns vote-timestamp,
    owns vote-weight;

# Dispute a proposal
relation dispute,
    relates disputer,
    relates disputed-proposal,
    owns dispute-id,
    owns dispute-reason,
    owns semantic-analysis,
    owns resolution-method,
    owns escalation-trigger,
    plays requires-escalation:escalation-reason;

# Proposal affects a rule
relation proposal-affects,
    relates proposing,
    relates affected-rule;

# Agent action tracking (for trust scoring)
relation agent-action,
    relates acting-agent,
    relates action-target,
    owns action-type,
    owns action-timestamp,
    owns action-outcome;

# Escalation indicator (inferred when human review required)
relation requires-escalation,
    relates escalated-proposal,
    relates escalation-reason;

# =============================================================================
# WORKSPACE & CAPABILITY RELATIONS (P2-12)
# =============================================================================

# Capability attributes (on the agent-capability relation)
attribute capability-category value string;
attribute capability-status value string;

# Agent → Rule capability binding
relation agent-capability,
    relates capable-agent,
    relates governing-rule,
    owns capability-category,
    owns capability-status;

# Project → Workspace assignment (EPIC-GOV-TASKS-V2)
relation project-has-workspace,
    relates owning-project,
    relates workspace-member;

# Workspace → Agent assignment
relation workspace-has-agent,
    relates agent-workspace,
    relates assigned-agent;

# Workspace → Task assignment (EPIC-GOV-TASKS-V2 Phase 4)
relation workspace-has-task,
    relates task-workspace,
    relates assigned-task;

# =============================================================================
# INFERENCE RULES
# =============================================================================

# Transitive rule dependency: if A depends on B and B depends on C, then A depends on C
rule transitive-dependency:
    when {
        (dependent: $a, dependency: $b) isa rule-dependency;
        (dependent: $b, dependency: $c) isa rule-dependency;
    } then {
        (dependent: $a, dependency: $c) isa rule-dependency;
    };

# Blocked task inference: DISABLED - TypeDB cannot modify existing attributes
# TODO: Redesign to use a separate "is-blocked" relation instead
# rule infer-blocked-task:
#     when {
#         $task isa task, has task-status "TODO";
#         $rule isa rule-entity, has status $s;
#         not { $s = "ACTIVE"; };
#         (blocked-task: $task, blocking-rule: $rule) isa task-blocked;
#     } then {
#         $task has task-status "BLOCKED";
#     };

# Cascade superseded: if decision A supersedes B, and B affects rule R, A now affects R
rule cascade-supersede:
    when {
        (superseding: $a, superseded: $b) isa decision-supersedes;
        (affecting-decision: $b, affected-rule: $r) isa decision-affects;
    } then {
        (affecting-decision: $a, affected-rule: $r) isa decision-affects;
    };

# Priority conflict: if two active rules in same category have different priorities
rule priority-conflict:
    when {
        $r1 isa rule-entity, has category $c, has priority $p1, has status "ACTIVE";
        $r2 isa rule-entity, has category $c, has priority $p2, has status "ACTIVE";
        not { $r1 is $r2; };
        not { $p1 = $p2; };
    } then {
        (conflicting-rule: $r1, conflicting-rule: $r2) isa rule-conflict;
    };

# =============================================================================
# MULTI-AGENT GOVERNANCE INFERENCE RULES (RULE-011)
# =============================================================================

# Trust score decay: Low compliance reduces trust
# NOTE: Trust score computation done externally, this is query-based
# Formula: Trust = (Compliance × 0.4) + (Accuracy × 0.3) + (Consistency × 0.2) + (Tenure × 0.1)

# Escalation required: Disputed proposals needing human review
rule escalation-required:
    when {
        $d (disputed-proposal: $p, disputer: $a) isa dispute, has resolution-method "escalate";
        $p isa proposal;
    } then {
        (escalated-proposal: $p, escalation-reason: $d) isa requires-escalation;
    };

# Proposal cascade: When a proposal affects a rule, it affects dependent rules too
rule proposal-cascade:
    when {
        (proposing: $p, affected-rule: $r1) isa proposal-affects;
        (dependent: $r2, dependency: $r1) isa rule-dependency;
    } then {
        (proposing: $p, affected-rule: $r2) isa proposal-affects;
    };

# Low trust vote weight: Agents with low trust get reduced vote weight
# NOTE: Vote weight is computed externally based on trust-score
# Low trust agents (< 0.5) have vote-weight = trust-score
# High trust agents (>= 0.5) have vote-weight = 1.0

# =============================================================================
# DOCUMENT CROSS-REFERENCING INFERENCE RULES (RULE-013)
# =============================================================================

