$rule018 isa rule-entity,
    has rule-id "RULE-018",
    has rule-name "Objective Reporting",
    has category "reporting",
    has priority "HIGH",
    has status "ACTIVE",
    has directive "Reports must be factual without flattery; prioritize accuracy over validation",
