# Sim.ai Governance Data
# Initial load: 22 rules + 4 decisions + 3 agents
# Created: 2024-12-24
# Updated: 2024-12-24 (RULE-015) - R&D Workflow, Enhanced RULE-004 with Executable Spec
# Updated: 2024-12-25 (RULE-016-020) - Infrastructure, Cross-Workspace, Reporting, UI/UX, E2E Testing
# Updated: 2024-12-25 (RULE-021-022) - MCP Healthcheck Protocol, Integrity Verification (Frankel Hash)

insert

# =============================================================================
# RULES (RULE-001 to RULE-008)
# =============================================================================

$rule001 isa rule-entity,
    has rule-id "RULE-001",
    has rule-name "Session Evidence Logging",
    has category "governance",
    has priority "CRITICAL",
    has status "ACTIVE",
    has directive "Every session MUST create evidence log in ./docs/SESSION-{date}-{topic}.md",
    has created-date 2024-12-24T00:00:00;

$rule002 isa rule-entity,
    has rule-id "RULE-002",
    has rule-name "Architectural Best Practices",
    has category "architecture",
    has priority "HIGH",
    has status "ACTIVE",
    has directive "Code reviews required, no hardcoded secrets in commits",
    has created-date 2024-12-24T00:00:00;

$rule003 isa rule-entity,
    has rule-id "RULE-003",
    has rule-name "Sync Protocol",
    has category "governance",
    has priority "HIGH",
    has status "DRAFT",
    has directive "Sync agent for skills/sessions synchronization",
    has created-date 2024-12-24T00:00:00;

$rule004 isa rule-entity,
    has rule-id "RULE-004",
    has rule-name "Exploratory Test Automation & Executable Specification",
    has category "testing",
    has priority "HIGH",
    has status "ACTIVE",
    has directive "Domain-specific heuristics (UI/API/Shell/Docker/Safety) with executable spec, evidence capture for audit, TDD cycle integration",
    has created-date 2024-12-24T00:00:00;

$rule005 isa rule-entity,
    has rule-id "RULE-005",
    has rule-name "Memory and MCP Stability",
    has category "stability",
    has priority "HIGH",
    has status "ACTIVE",
    has directive "Memory thresholds monitored, MCP tiers respected",
    has created-date 2024-12-24T00:00:00;

$rule006 isa rule-entity,
    has rule-id "RULE-006",
    has rule-name "Decision Logging",
    has category "governance",
    has priority "MEDIUM",
    has status "ACTIVE",
    has directive "Log decisions in evidence/SESSION-DECISIONS-*.md",
    has created-date 2024-12-24T00:00:00;

$rule007 isa rule-entity,
    has rule-id "RULE-007",
    has rule-name "MCP Usage Protocol",
    has category "productivity",
    has priority "HIGH",
    has status "ACTIVE",
    has directive "Sessions MUST actively leverage available MCPs",
    has created-date 2024-12-24T00:00:00;

$rule008 isa rule-entity,
    has rule-id "RULE-008",
    has rule-name "In-House Rewrite Principle",
    has category "strategic",
    has priority "CRITICAL",
    has status "ACTIVE",
    has directive "Prefer technologies with tests (rewrite warranty)",
    has created-date 2024-12-24T00:00:00;

$rule009 isa rule-entity,
    has rule-id "RULE-009",
    has rule-name "Version Compatibility Protocol",
    has category "devops",
    has priority "CRITICAL",
    has status "ACTIVE",
    has directive "Pin versions for reproducibility, test migrations before deploying",
    has created-date 2024-12-24T00:00:00;

$rule010 isa rule-entity,
    has rule-id "RULE-010",
    has rule-name "Evidence-Based Wisdom Accumulation",
    has category "strategic",
    has priority "CRITICAL",
    has status "ACTIVE",
    has directive "All insights stored as testable hypotheses, validated before adoption",
    has created-date 2024-12-24T00:00:00;

$rule011 isa rule-entity,
    has rule-id "RULE-011",
    has rule-name "Multi-Agent Governance Protocol",
    has category "governance",
    has priority "CRITICAL",
    has status "ACTIVE",
    has directive "Bicameral model: Human oversight + AI execution, MCP manages DB state",
    has created-date 2024-12-24T00:00:00;

$rule012 isa rule-entity,
    has rule-id "RULE-012",
    has rule-name "Deep Sleep Protocol",
    has category "workflow",
    has priority "HIGH",
    has status "ACTIVE",
    has directive "DSP phases: AUDIT → HYPOTHESIZE → MEASURE → OPTIMIZE → VALIDATE for backlog hygiene",
    has created-date 2024-12-24T00:00:00;

$rule013 isa rule-entity,
    has rule-id "RULE-013",
    has rule-name "Rules Applicability Convention",
    has category "traceability",
    has priority "MEDIUM",
    has status "ACTIVE",
    has directive "Format: {TYPE}({RULE-ID}): {Description} - gaps/TODOs must reference governing rules",
    has created-date 2024-12-24T00:00:00;

$rule014 isa rule-entity,
    has rule-id "RULE-014",
    has rule-name "Autonomous Task Sequencing",
    has category "autonomy",
    has priority "CRITICAL",
    has status "ACTIVE",
    has directive "Prioritize by product strategy, continue until HALT command (STOP|HALT|STAI|RED ALERT|ALERT)",
    has created-date 2024-12-24T00:00:00;

$rule015 isa rule-entity,
    has rule-id "RULE-015",
    has rule-name "R&D Workflow with Human Approval Gate",
    has category "autonomy",
    has priority "CRITICAL",
    has status "ACTIVE",
    has directive "R&D tasks require human approval unless DEEP autonomy mandated; budget flags: LOW/MEDIUM/HIGH/CRITICAL",
    has created-date 2024-12-24T00:00:00;

# =============================================================================
# AGENTS (for multi-agent governance)
# =============================================================================

$agent_claude isa agent,
    has agent-id "AGENT-001",
    has agent-name "Claude Code R&D",
    has agent-type "claude-code",
    has trust-score 0.95,
    has compliance-rate 0.98,
    has accuracy-rate 0.92,
    has tenure-days 30;

$agent_docker isa agent,
    has agent-id "AGENT-002",
    has agent-name "Docker Production Agent",
    has agent-type "docker-agent",
    has trust-score 0.80,
    has compliance-rate 0.90,
    has accuracy-rate 0.85,
    has tenure-days 7;

$agent_sync isa agent,
    has agent-id "AGENT-003",
    has agent-name "Sync Protocol Agent",
    has agent-type "sync-agent",
    has trust-score 0.75,
    has compliance-rate 0.85,
    has accuracy-rate 0.80,
    has tenure-days 1;

# =============================================================================
# DECISIONS (DECISION-001 to DECISION-004)
# =============================================================================

$dec001 isa decision,
    has decision-id "DECISION-001",
    has decision-name "Remove Opik from Stack",
    has context "Evaluating if 8-service Opik is justified",
    has rationale "Overkill for current needs, not connected to workflow",
    has decision-status "IMPLEMENTED",
    has decision-date 2024-12-24T00:00:00;

$dec002 isa decision,
    has decision-id "DECISION-002",
    has decision-name "Mem0 Knowledge Governance",
    has context "MCPs configured but not actively used",
    has rationale "Superseded by TypeDB approach",
    has decision-status "SUPERSEDED",
    has decision-date 2024-12-24T00:00:00;

$dec003 isa decision,
    has decision-id "DECISION-003",
    has decision-name "TypeDB Priority Elevation",
    has context "Strategic R&D reassessment",
    has rationale "Inference and reasoning over vector storage",
    has decision-status "APPROVED",
    has decision-date 2024-12-24T00:00:00;

$dec004 isa decision,
    has decision-id "DECISION-004",
    has decision-name "No Enterprise Lockdown",
    has context "Evaluated Claude enterprise vs open-source",
    has rationale "Build incrementally on own stack, avoid vendor lock-in",
    has decision-status "APPROVED",
    has decision-date 2024-12-24T00:00:00;

# =============================================================================
# RELATIONSHIPS
# =============================================================================

# Rule dependencies
(dependent: $rule006, dependency: $rule001) isa rule-dependency;  # Decision logging depends on session evidence
(dependent: $rule007, dependency: $rule005) isa rule-dependency;  # MCP usage depends on stability

# Decision affects rules
(affecting-decision: $dec001, affected-rule: $rule005) isa decision-affects;  # Removing Opik affects stability
(affecting-decision: $dec003, affected-rule: $rule008) isa decision-affects;  # TypeDB decision influenced by rewrite principle
(affecting-decision: $dec004, affected-rule: $rule008) isa decision-affects;  # No lockdown enforces rewrite principle

# Decision supersedes
(superseding: $dec003, superseded: $dec002) isa decision-supersedes;  # TypeDB supersedes Mem0

# Additional rule dependencies (RULE-011)
(dependent: $rule009, dependency: $rule002) isa rule-dependency;  # Version protocol depends on architecture
(dependent: $rule010, dependency: $rule001) isa rule-dependency;  # Evidence wisdom depends on session logging
(dependent: $rule010, dependency: $rule006) isa rule-dependency;  # Evidence wisdom depends on decision logging
(dependent: $rule011, dependency: $rule001) isa rule-dependency;  # Governance protocol depends on evidence
(dependent: $rule011, dependency: $rule010) isa rule-dependency;  # Governance protocol depends on evidence-based wisdom

# Rule dependencies (RULE-012, RULE-013, RULE-014)
(dependent: $rule012, dependency: $rule001) isa rule-dependency;  # DSP depends on session evidence logging
(dependent: $rule012, dependency: $rule007) isa rule-dependency;  # DSP uses MCP protocol for queries
(dependent: $rule013, dependency: $rule006) isa rule-dependency;  # Applicability depends on decision logging
(dependent: $rule013, dependency: $rule012) isa rule-dependency;  # Applicability convention supports DSP audits
(dependent: $rule014, dependency: $rule012) isa rule-dependency;  # Task sequencing integrates with DSP hygiene
(dependent: $rule014, dependency: $rule008) isa rule-dependency;  # Task sequencing follows strategic priorities

# Rule dependencies (RULE-015)
(dependent: $rule015, dependency: $rule014) isa rule-dependency;  # R&D workflow extends task sequencing
(dependent: $rule015, dependency: $rule008) isa rule-dependency;  # R&D uses technology scorecard
(dependent: $rule015, dependency: $rule010) isa rule-dependency;  # R&D requires evidence-based approach

# =============================================================================
# RULES (RULE-016 to RULE-020) - Added 2024-12-25
# =============================================================================

$rule016 isa rule-entity,
    has rule-id "RULE-016",
    has rule-name "Infrastructure Identity & Hardware",
    has category "devops",
    has priority "CRITICAL",
    has status "ACTIVE",
    has directive "Document hardware specs, maintain machine identity registry, track GPU/CUDA capabilities",
    has created-date 2024-12-24T00:00:00;

$rule017 isa rule-entity,
    has rule-id "RULE-017",
    has rule-name "Cross-Workspace Pattern Reuse",
    has category "strategic",
    has priority "HIGH",
    has status "ACTIVE",
    has directive "Reuse patterns across workspaces via cross-workspace wisdom collection",
    has created-date 2024-12-24T00:00:00;

$rule018 isa rule-entity,
    has rule-id "RULE-018",
    has rule-name "Objective Reporting",
    has category "reporting",
    has priority "HIGH",
    has status "ACTIVE",
    has directive "Reports must be factual without flattery; prioritize accuracy over validation",
    has created-date 2024-12-24T00:00:00;

$rule019 isa rule-entity,
    has rule-id "RULE-019",
    has rule-name "UI/UX Design Standards",
    has category "reporting",
    has priority "HIGH",
    has status "ACTIVE",
    has directive "Follow accessibility (WCAG), responsive design, consistent components, dark mode support",
    has created-date 2024-12-24T00:00:00;

$rule020 isa rule-entity,
    has rule-id "RULE-020",
    has rule-name "LLM-Driven E2E Test Generation",
    has category "testing",
    has priority "HIGH",
    has status "ACTIVE",
    has directive "E2E via LLM exploration -> deterministic Robot tests; LLM only for explore/analyze, not runtime",
    has created-date 2024-12-25T00:00:00;

# =============================================================================
# RULE DEPENDENCIES (RULE-016 to RULE-020)
# =============================================================================

# RULE-016 depends on RULE-002 (architecture) and RULE-009 (version compatibility)
(dependent: $rule016, dependency: $rule002) isa rule-dependency;
(dependent: $rule016, dependency: $rule009) isa rule-dependency;

# RULE-017 depends on RULE-010 (evidence-based wisdom) and RULE-001 (session logging)
(dependent: $rule017, dependency: $rule010) isa rule-dependency;
(dependent: $rule017, dependency: $rule001) isa rule-dependency;

# RULE-018 depends on RULE-001 (session logging) and RULE-006 (decision logging)
(dependent: $rule018, dependency: $rule001) isa rule-dependency;
(dependent: $rule018, dependency: $rule006) isa rule-dependency;

# RULE-019 depends on RULE-018 (objective reporting)
(dependent: $rule019, dependency: $rule018) isa rule-dependency;

# RULE-020 depends on RULE-004 (exploratory testing) and RULE-007 (MCP usage)
(dependent: $rule020, dependency: $rule004) isa rule-dependency;
(dependent: $rule020, dependency: $rule007) isa rule-dependency;

# =============================================================================
# RULES (RULE-021 to RULE-022) - Added 2024-12-25 (Session 2)
# =============================================================================

$rule021 isa rule-entity,
    has rule-id "RULE-021",
    has rule-name "MCP Healthcheck Protocol",
    has category "stability",
    has priority "CRITICAL",
    has status "ACTIVE",
    has directive "Every MCP operation must verify server health; failures logged and recovery attempted before failing",
    has created-date 2024-12-25T00:00:00;

$rule022 isa rule-entity,
    has rule-id "RULE-022",
    has rule-name "Integrity Verification (Frankel Hash)",
    has category "security",
    has priority "HIGH",
    has status "DRAFT",
    has directive "Critical files must have integrity verification via Frankel Hash for similarity detection and change tracking",
    has created-date 2024-12-25T00:00:00;

# =============================================================================
# RULE DEPENDENCIES (RULE-021 to RULE-022)
# =============================================================================

# RULE-021 depends on RULE-005 (memory stability) and RULE-007 (MCP usage)
(dependent: $rule021, dependency: $rule005) isa rule-dependency;
(dependent: $rule021, dependency: $rule007) isa rule-dependency;

# RULE-022 depends on RULE-001 (session logging) and RULE-010 (evidence-based wisdom)
(dependent: $rule022, dependency: $rule001) isa rule-dependency;
(dependent: $rule022, dependency: $rule010) isa rule-dependency;
