    has directive "E2E via LLM exploration -> deterministic Robot tests; LLM only for explore/analyze, not runtime",
    has created-date 2024-12-25T00:00:00;

# =============================================================================
# RULE DEPENDENCIES (RULE-016 to RULE-020)
# =============================================================================

# RULE-016 depends on RULE-002 (architecture) and RULE-009 (version compatibility)
(dependent: $rule016, dependency: $rule002) isa rule-dependency;
(dependent: $rule016, dependency: $rule009) isa rule-dependency;

# RULE-017 depends on RULE-010 (evidence-based wisdom) and RULE-001 (session logging)
(dependent: $rule017, dependency: $rule010) isa rule-dependency;
(dependent: $rule017, dependency: $rule001) isa rule-dependency;

# RULE-018 depends on RULE-001 (session logging) and RULE-006 (decision logging)
(dependent: $rule018, dependency: $rule001) isa rule-dependency;
(dependent: $rule018, dependency: $rule006) isa rule-dependency;

# RULE-019 depends on RULE-018 (objective reporting)
(dependent: $rule019, dependency: $rule018) isa rule-dependency;

# RULE-020 depends on RULE-004 (exploratory testing) and RULE-007 (MCP usage)
(dependent: $rule020, dependency: $rule004) isa rule-dependency;
(dependent: $rule020, dependency: $rule007) isa rule-dependency;

# =============================================================================
# RULES (RULE-021 to RULE-022) - Added 2024-12-25 (Session 2)
# =============================================================================

$rule021 isa rule-entity,
    has rule-id "RULE-021",
    has rule-name "MCP Healthcheck Protocol",
    has category "stability",
    has priority "CRITICAL",
    has status "ACTIVE",
    has directive "Every MCP operation must verify server health; failures logged and recovery attempted before failing",
    has created-date 2024-12-25T00:00:00;

$rule022 isa rule-entity,
    has rule-id "RULE-022",
    has rule-name "Integrity Verification (Frankel Hash)",
    has category "security",
    has priority "HIGH",
    has status "DRAFT",
    has directive "Critical files must have integrity verification via Frankel Hash for similarity detection and change tracking",
    has created-date 2024-12-25T00:00:00;

# =============================================================================
# RULES (RULE-023 to RULE-025) - Added 2024-12-26
# =============================================================================

$rule023 isa rule-entity,
    has rule-id "RULE-023",
    has rule-name "Test Before Ship",
    has category "quality",
    has priority "CRITICAL",
    has status "ACTIVE",
    has directive "All code changes MUST pass tests before commit; no shipping untested code; test failures block deployment",
    has created-date 2024-12-25T00:00:00;

$rule024 isa rule-entity,
    has rule-id "RULE-024",
    has rule-name "AMNESIA Protocol (Context Recovery)",
    has category "maintenance",
    has priority "CRITICAL",
    has status "ACTIVE",
    has directive "Context recovery must use hierarchical sources: TODO.md -> R&D-BACKLOG -> Session Summary -> Claude-Mem -> GAP-INDEX; never ask user 'what were we doing?'",
    has created-date 2024-12-25T00:00:00;

$rule025 isa rule-entity,
    has rule-id "RULE-025",
    has rule-name "Test Data Integrity Requirements",
    has category "testing",
    has priority "HIGH",
    has status "DRAFT",
    has directive "All tests MUST validate API returns data before UI assertions; tests passing with empty data are invalid; use realistic mocks not empty collections",
    has created-date 2024-12-26T00:00:00;

# =============================================================================
# RULE DEPENDENCIES (RULE-021 to RULE-025)
# =============================================================================

# RULE-021 depends on RULE-005 (memory stability) and RULE-007 (MCP usage)
