# Sim.ai PoC Environment Variables
# Copy to .env and configure before running

# =============================================================================
# REQUIRED: Anthropic API Key for Claude models
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-your-key-here

# =============================================================================
# OPTIONAL: xAI API Key for Grok models
# =============================================================================
XAI_API_KEY=xai-your-key-here

# =============================================================================
# LITELLM Configuration
# =============================================================================
LITELLM_MASTER_KEY=sk-litellm-master-key-change-me

# =============================================================================
# MODEL SELECTION
# =============================================================================
# Primary model (via LiteLLM): claude-opus, claude-sonnet, gemma-local, llama-local
MODEL_NAME=claude-opus
# Local fallback model for simple tasks
LOCAL_MODEL_NAME=gemma3:4b

# =============================================================================
# CHROMADB Authentication (optional for local dev)
# =============================================================================
CHROMA_AUTH_TOKEN=chroma-token-dev

# =============================================================================
# OPIK Configuration (optional)
# =============================================================================
OPIK_API_KEY=
OPIK_WORKSPACE=default

# =============================================================================
# EMBEDDING CONFIGURATION (GAP-EMBED-001)
# =============================================================================
# Set to "true" ONLY for testing - production should use real embeddings
USE_MOCK_EMBEDDINGS=false
# Provider: "ollama" (default), "litellm", or "mock"
EMBEDDING_PROVIDER=ollama
# Ollama server (default: localhost:11434)
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
# LiteLLM proxy (default: localhost:4000)
LITELLM_HOST=localhost
LITELLM_PORT=4000
