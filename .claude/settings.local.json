{
  "permissions": {
    "allow": [
      "Bash(powershell:*)",
      "Bash(curl:*)",
      "Skill(remember)",
      "Skill(save)",
      "Bash(podman:*)",
      "Bash(kubectl version:*)",
      "Bash(podman-compose:*)",
      "Bash(pip install:*)",
      "Bash(pip3 --version:*)",
      "Bash(systemctl:*)",
      "Bash(bash -c 'echo > /dev/tcp/localhost/1729')",
      "Bash(bash -c 'echo > /dev/tcp/localhost/11434')",
      "Bash(bash -c 'echo > /dev/tcp/localhost/7777')",
      "Bash(ls:*)",
      "Bash(du:*)",
      "Bash(docker exec:*)",
      "Bash(/usr/bin/podman info:*)",
      "Skill(entropy)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(CONTAINERS_STORAGE_CONF=/dev/null podman system reset:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "claude-mem",
    "rest-api",
    "gov-core",
    "gov-agents",
    "gov-sessions",
    "gov-tasks",
    "playwright"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/healthcheck.py\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/checkers/mcp_connection.py\" --quick",
            "timeout": 3
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/prompt_healthcheck.py\"",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/checkers/session_reporter.py\"",
            "timeout": 2
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre_bash_check.py\"",
            "timeout": 2
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/entropy_cli.py\" --increment -q",
            "timeout": 1
          }
        ]
      }
    ]
  }
}
